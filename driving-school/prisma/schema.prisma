// Prisma schema for Driving School Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  COACH
  ADMIN
}

enum LicenseType {
  C1
  C2
  B1
  B2
  A1
  A2
  A3
  D
  E
  F
}

enum StudyPhase {
  SUBJECT_1
  SUBJECT_2
  SUBJECT_3
  SUBJECT_4
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ExamStatus {
  NOT_TAKEN
  PASSED
  FAILED
}

enum LicenseStatus {
  NOT_APPLIED
  APPLYING
  LEARNING
  TESTING
  OBTAINED
  REVOKED
}

enum CourseType {
  SUBJECT_2
  SUBJECT_3
  REFRESHER
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  phone     String?
  avatar    String?
  role      UserRole @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student?
  coach   Coach?
}

model Student {
  id             Int           @id @default(autoincrement())
  userId         Int           @unique
  user           User          @relation(fields: [userId], references: [id])
  idNumber       String?       @unique
  licenseType    LicenseType   @default(C1)
  studyPhase     StudyPhase    @default(SUBJECT_1)
  licenseStatus  LicenseStatus @default(NOT_APPLIED)
  enrollDate     DateTime?
  totalHours     Float         @default(0)
  completedHours Float         @default(0)
  coachId        Int?
  coach          Coach?        @relation(fields: [coachId], references: [id])

  bookings      Booking[]
  examRecords   ExamRecord[]
  payments      Payment[]
  notifications Notification[]
  reviews       Review[]

  @@index([coachId])
}

model Coach {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  user           User     @relation(fields: [userId], references: [id])
  licenseNumber  String?
  experience     Int      @default(0)
  rating         Float    @default(0)
  totalReviews   Int      @default(0)
  bio            String?
  specialties    String?
  pricePerHour   Float    @default(100)
  status         String   @default("active")
  avatar         String?

  students       Student[]
  courses        Course[]
  bookings       Booking[]
  reviews        Review[]
  schedules      Schedule[]

  @@index([status])
}

model Course {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  courseType  CourseType
  coachId     Int
  coach       Coach      @relation(fields: [coachId], references: [id])
  duration    Float      @default(1)
  price       Float      @default(100)
  capacity    Int        @default(1)
  status      String     @default("active")

  bookings    Booking[]
  schedules   Schedule[]

  @@index([coachId])
  @@index([courseType])
}

model Schedule {
  id        Int      @id @default(autoincrement())
  coachId   Int
  coach     Coach    @relation(fields: [coachId], references: [id])
  courseId  Int?
  course    Course?  @relation(fields: [courseId], references: [id])
  date      DateTime
  startTime DateTime
  endTime   DateTime
  isAvailable Boolean @default(true)
  location  String?

  bookings  Booking[]

  @@index([coachId, date])
  @@index([isAvailable])
}

model Booking {
  id          Int           @id @default(autoincrement())
  studentId   Int
  student     Student       @relation(fields: [studentId], references: [id])
  coachId     Int
  coach       Coach         @relation(fields: [coachId], references: [id])
  scheduleId  Int?
  schedule    Schedule?     @relation(fields: [scheduleId], references: [id])
  courseId    Int?
  course      Course?       @relation(fields: [courseId], references: [id])
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([studentId])
  @@index([coachId, date])
  @@index([status])
}

model ExamRecord {
  id            Int        @id @default(autoincrement())
  studentId     Int
  student       Student    @relation(fields: [studentId], references: [id])
  examType      StudyPhase
  examDate      DateTime
  score         Float?
  status        ExamStatus @default(NOT_TAKEN)
  location      String?
  notes         String?
  certificateUrl String?

  @@index([studentId])
  @@index([examType])
}

model Review {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  coachId   Int
  coach     Coach    @relation(fields: [coachId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([coachId])
}

model Payment {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  amount      Float
  paymentType String
  status      String   @default("pending")
  orderId     String?
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([studentId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  title     String
  content   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([studentId, isRead])
}
